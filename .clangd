CompileFlags:
  Add:
    - -I/usr/local/cuda-12.3/targets/x86_64-linux/include
    - --cuda-gpu-arch=sm_86
    - -x
    - cuda
  Remove:
    - -G
    - -lineinfo
    - --generate-line-info
    - --use_fast_math
    - -forward-unknown-to-host-compiler
    - --options-file
    - -Xcompiler*
    - --generate-code=arch=compute_86,code=[compute_86,sm_86]

